# ═══════════════════════════════════════════════════════════════════════════════
# Backend .gitignore - Exclude sensitive and unnecessary files from version control
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT & SENSITIVE FILES (CRITICAL!)
# ─────────────────────────────────────────────────────────────────────────────
.env                    # Local environment variables (NEVER commit!)
.env.local              # Local overrides
.env.*.local            # Environment-specific local files
.env.development        # Development environment
.env.production         # Production environment

# ─────────────────────────────────────────────────────────────────────────────
# DEPENDENCIES
# ─────────────────────────────────────────────────────────────────────────────
node_modules/           # NPM dependencies (install with npm install)
package-lock.json       # NPM lock file (regenerate with npm install)
yarn.lock               # Yarn lock file

# ─────────────────────────────────────────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────────────────────────────────────────
*.log                   # General log files
npm-debug.log*          # NPM debug logs
yarn-debug.log*         # Yarn debug logs
lerna-debug.log*        # Lerna debug logs
logs/                   # Log directory

# ─────────────────────────────────────────────────────────────────────────────
# IDE & EDITOR
# ─────────────────────────────────────────────────────────────────────────────
.vscode/                # VS Code settings
.idea/                  # IntelliJ IDE
*.swp                   # Vim swap files
*.swo                   # Vim swap files
*~                      # Backup files

# ─────────────────────────────────────────────────────────────────────────────
# OS SPECIFIC
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store               # macOS files
Thumbs.db               # Windows thumbnail cache

# ─────────────────────────────────────────────────────────────────────────────
# RUNTIME & BUILD
# ─────────────────────────────────────────────────────────────────────────────
dist/                   # Distribution directory
build/                  # Build directory
.next/                  # Next.js build
coverage/               # Code coverage reports

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────
*.sqlite                # SQLite database
*.sqlite3               # SQLite3 database
*.db                    # Database files
mongo_data/             # Local MongoDB data

# ─────────────────────────────────────────────────────────────────────────────
# TEMPORARY FILES
# ─────────────────────────────────────────────────────────────────────────────
.tmp/                   # Temporary files
tmp/                    # Temporary directory
temp/                   # Temporary files
*.tmp                   # Temporary files
uploads/                # User uploaded files

# ─────────────────────────────────────────────────────────────────────────────
# CACHE
# ─────────────────────────────────────────────────────────────────────────────
.cache/                 # Cache directory
cache/                  # Cache directory
.eslintcache            # ESLint cache

# ─────────────────────────────────────────────────────────────────────────────
# PROCESS MANAGEMENT
# ─────────────────────────────────────────────────────────────────────────────
.pm2/                   # PM2 configuration
pids/                   # Process IDs

